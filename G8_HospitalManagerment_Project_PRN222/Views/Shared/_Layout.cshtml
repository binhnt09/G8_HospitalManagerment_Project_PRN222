<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - G8_HospitalManagerment_Project_PRN222</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/G8_HospitalManagerment_Project_PRN222.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
    <body>
        <header class="sticky-top">
            <nav class="navbar navbar-expand-lg navbar-custom">
                <div class="container"> <a class="navbar-brand navbar-brand-custom" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-hospital"></i> ChildCare
                    </a>
            
                    <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
            
                    <div class="collapse navbar-collapse" id="mainNavbar">
                
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0 mx-lg-auto">
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                            </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-area="" asp-controller="Users" asp-action="Index">Người dùng</a>
                            </li>
                        }
                        @if ( User == null && !User.IsInRole("Patients"))
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-area="" asp-controller="Patients" asp-action="Index">Quản lý</a>
                            </li>
                        }
                    
                            <li class="nav-item dropdown">
                                <a class="nav-link nav-link-custom dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Danh mục
                                </a>
                                <ul class="dropdown-menu dropdown-menu-custom" aria-labelledby="navbarDropdown">
                                    <li><a class="dropdown-item dropdown-item-custom" asp-controller="Departments" asp-action="Index"><i class="bi bi-building me-2"></i> Phòng ban</a></li>
                                    <li><a class="dropdown-item dropdown-item-custom" asp-controller="Drugs" asp-action="Index"><i class="bi bi-capsule me-2"></i> Thuốc & Vật tư</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item dropdown-item-custom" asp-controller="Employees" asp-action="Index"><i class="bi bi-person-badge me-2"></i> Nhân viên y tế</a></li>
                                </ul>
                            </li>
                        </ul>

                    <div class="d-flex align-items-center gap-2 mt-3 mt-lg-0">
                        @{
                            var userName = @User.Identity.Name;
                        }

                        @if (string.IsNullOrEmpty(userName))
                        {
                            <!-- CHƯA LOGIN -->
                            <a asp-controller="Authentication"
                               asp-action="Login"
                               class="auth-btn-login">
                                Đăng nhập
                            </a>

                            <a asp-controller="Authentication"
                               asp-action="Register"
                               class="auth-btn-register">
                                Đăng ký ngay
                            </a>
                        }
                        else
                        {
                            <!-- ĐÃ LOGIN -->
                            <div class="dropdown">

                                @if (!string.IsNullOrEmpty(userName))
                                {
                                    <button class="btn btn-light dropdown-toggle fw-bold"
                                            type="button"
                                            data-bs-toggle="dropdown">
                                        👤 @userName
                                    </button>

                                    <ul class="dropdown-menu dropdown-menu-end">

                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="Users"
                                               asp-action="Profile">
                                                👤 Xem tài khoản
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="Authentication"
                                               asp-action="ChangePassword">
                                                🔐 Đổi mật khẩu
                                            </a>
                                        </li>
                                        
                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="Appointments"
                                               asp-action="MyAppointments">
                                                📅 Lịch hẹn của tôi
                                            </a>
                                        </li>

                                        <li><hr class="dropdown-divider"></li>

                                        <li>
                                            <form asp-controller="Authentication"
                                                  asp-action="Logout"
                                                  method="post">
                                                <button type="submit"
                                                        class="dropdown-item text-danger">
                                                    🚪 Đăng xuất
                                                </button>
                                            </form>
                                        </li>

                                    </ul>
                                }
                            </div>
                        }
                    </div>
                
                    </div>
                </div>
            </nav>
        </header>
        <div class="container-fluid p-0">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; 2026 - G8_HospitalManagerment_Project_PRN222 - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </footer>
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        <script src="~/microsoft/signalr/dist/browser/signalr.js"></script>

        <script>
            // 1. Kết nối với Đài phát thanh "/dataHub"
            var connection = new signalR.HubConnectionBuilder().withUrl("/dataHub").build();

            // 2. Lắng nghe sự kiện có tên là "ReceiveDataChange"
            connection.on("ReceiveDataChange", function () {

                // --- LOGIC SMART RELOAD CỦA BẠN NẰM Ở ĐÂY ---
                var currentUrl = window.location.href.toLowerCase();

                // Nếu URL có chứa chữ create hoặc edit (đang gõ form) -> Chỉ hiện thông báo
            if (currentUrl.includes("create") || currentUrl.includes("edit") || currentUrl.includes("delete")) {
                    // Chỗ này bạn có thể thay alert bằng Toastr hoặc Bootstrap Toast cho đẹp
                    alert("Có người vừa cập nhật dữ liệu. Vui lòng tải lại trang sau khi bạn lưu xong để tránh lỗi đồng bộ!");
                }
                // Nếu đang ở trang Index (danh sách) hoặc Details -> F5 tự động luôn
                else {
                    window.location.reload();
                }
            });

            // 3. Khởi động kết nối
            connection.start().then(function () {
                console.log("SignalR Connected!");
            }).catch(function (err) {
                return console.error(err.toString());
            });
        </script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>

    <style>
        /* CSS Custom cho Navbar */
        .navbar-custom {
            background-color: #ffffff;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            padding: 12px 0;
        }
        .navbar-brand-custom {
            color: #0D6EFD !important;
            font-weight: 800;
            font-size: 1.5rem;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .nav-link-custom {
            font-weight: 600;
            color: #4A5568 !important; /* Màu xám đậm */
            padding: 8px 16px !important;
            border-radius: 8px;
            transition: all 0.2s ease;
            margin: 0 4px;
        }
        .nav-link-custom:hover, .nav-link-custom.active {
            color: #0D6EFD !important;
            background-color: #F0F7FF;
        }
        .dropdown-menu-custom {
            border: none;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            border-radius: 12px;
            padding: 10px;
        }
        .dropdown-item-custom {
            border-radius: 8px;
            font-weight: 500;
            padding: 8px 16px;
            transition: all 0.2s;
        }
        .dropdown-item-custom:hover {
            background-color: #F0F7FF;
            color: #0D6EFD;
        }
    
        /* Cụm nút Đăng nhập / Đăng ký */
        .auth-btn-login {
            color: #0D6EFD;
            font-weight: 600;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 12px;
            transition: all 0.2s;
        }
        .auth-btn-login:hover {
            background-color: #F0F7FF;
        }
        .auth-btn-register {
            background-color: #0D6EFD;
            color: white !important;
            font-weight: 600;
            text-decoration: none;
            padding: 10px 24px;
            border-radius: 12px;
            transition: all 0.2s;
            box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2);
        }
        .auth-btn-register:hover {
            background-color: #0b5ed7;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(13, 110, 253, 0.3);
        }
    </style>
</html>
