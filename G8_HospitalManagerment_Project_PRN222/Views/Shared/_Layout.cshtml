<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - G8_HospitalManagerment_Project_PRN222</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/G8_HospitalManagerment_Project_PRN222.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">G8_PRN222</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Users" asp-action="Index">User</a>
                        </li>
                        <ul class="navbar-nav flex-grow-1">

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Patients" asp-action="Index">Patients</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Doctors" asp-action="Index">Doctors</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Appointments" asp-action="Index">Appointments</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Invoices" asp-action="Index">Invoices</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="LabOrders" asp-action="Index">LabOrders</a>
                            </li>

                            <!-- Dropdown -->
                            <li class="nav-item dropdown">

                                <a class="nav-link dropdown-toggle text-dark"
                                   href="#"
                                   id="navbarDropdown"
                                   role="button"
                                   data-bs-toggle="dropdown">

                                    More
                                </a>

                                <ul class="dropdown-menu">

                                    <li>
                                        <a class="dropdown-item" asp-controller="Departments" asp-action="Index">Departments</a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="Drugs" asp-action="Index">Drugs</a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="Employees" asp-action="Index">Employees</a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="MedicalRecords" asp-action="Index">Medical Records</a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="Payments" asp-action="Index">Payments</a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="LabOrders" asp-action="Index">Lab Orders</a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="LabResults" asp-action="Index">Lab Results</a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="Users" asp-action="Index">Users</a>
                                    </li>

                                </ul>

                            </li>
                            <li>
                                <a asp-controller="Authentication" asp-action="Index" asp-route-mode="login">
                                    Đăng nhập
                                </a>

                                <a asp-controller="Authentication" asp-action="Index" asp-route-mode="register">
                                    Đăng ký
                                </a>
                            </li>

                        </ul>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - G8_HospitalManagerment_Project_PRN222 - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
