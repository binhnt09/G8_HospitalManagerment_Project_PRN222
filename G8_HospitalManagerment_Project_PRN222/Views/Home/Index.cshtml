@{
    ViewData["Title"] = "Trang chủ - ChildCare Center";
}

<section class="hero-wrapper mb-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <span class="badge bg-soft-blue text-medical px-3 py-2 rounded-pill mb-3 fw-bold border border-primary-subtle">
                    <i class="bi bi-shield-plus"></i> ⭐ Trung tâm Nhi khoa Hàng đầu
                </span>
                <h1 class="display-4 fw-bolder text-dark mb-4" style="line-height: 1.2;">
                    Chăm sóc sức khỏe <br> <span class="text-medical">toàn diện</span> cho con yêu
                </h1>
                <p class="lead text-muted mb-5 fs-5">
                    Đội ngũ bác sĩ chuyên khoa giàu kinh nghiệm, trang thiết bị hiện đại cùng không gian thân thiện, giúp bé luôn khỏe mạnh và nụ cười luôn rạng rỡ.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/Appointments/Create" class="btn btn-medical d-flex align-items-center gap-2">
                        <i class="bi bi-calendar2-check"></i> Đặt lịch khám ngay
                    </a>
                    <a href="/services" class="btn btn-outline-medical d-flex align-items-center gap-2">
                        Tìm hiểu dịch vụ <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <img src="https://images.unsplash.com/photo-1632833239869-a37e3a5806d2?w=800" alt="Doctor with child" class="img-fluid" style="border-radius: 30px; box-shadow: 0 20px 40px rgba(0,0,0,0.1);">
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h6 class="text-medical fw-bold text-uppercase tracking-wider">Lợi thế của chúng tôi</h6>
            <h2 class="fw-bold text-dark">Vì sao ba mẹ tin tưởng ChildCare?</h2>
        </div>

        <div class="row g-4">
            <div class="col-md-3">
                <div class="medical-card p-4">
                    <div class="feature-icon-box"><i class="bi bi-heart-pulse"></i></div>
                    <h5 class="fw-bold mb-3">Tận tâm & Yêu trẻ</h5>
                    <p class="text-muted mb-0">Đội ngũ y bác sĩ không chỉ giỏi chuyên môn mà còn thấu hiểu tâm lý trẻ nhỏ.</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="medical-card p-4">
                    <div class="feature-icon-box"><i class="bi bi-clock-history"></i></div>
                    <h5 class="fw-bold mb-3">Hỗ trợ 24/7</h5>
                    <p class="text-muted mb-0">Hệ thống tổng đài và đặt lịch trực tuyến hoạt động liên tục, sẵn sàng khi bạn cần.</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="medical-card p-4">
                    <div class="feature-icon-box"><i class="bi bi-hospital"></i></div>
                    <h5 class="fw-bold mb-3">Cơ sở hiện đại</h5>
                    <p class="text-muted mb-0">Trang thiết bị y tế tân tiến, phòng khám sạch sẽ, đạt tiêu chuẩn quốc tế.</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="medical-card p-4">
                    <div class="feature-icon-box"><i class="bi bi-shield-check"></i></div>
                    <h5 class="fw-bold mb-3">Quy trình chuẩn</h5>
                    <p class="text-muted mb-0">Thăm khám nhanh chóng, chẩn đoán chính xác, phác đồ điều trị an toàn.</p>
                </div>
            </div>
        </div>
    </div>
</section>

