@using G8_HospitalManagerment_Project_PRN222.Models.ViewModels
@model DoctorViewModel
<div class="card shadow-sm">
    <div class="card-header bg-primary text-white"><h4>Chỉnh sửa thông tin</h4></div>
    <div class="card-body">
        <form asp-action="Edit">
            <input type="hidden" asp-for="DoctorId" />
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label>Mã nhân viên (Không được sửa)</label>
                    <input asp-for="EmployeeCode" class="form-control" readonly />
                </div>
                <div class="col-md-6 mb-3">
                    <label>Khoa chuyên môn</label>
                    <select asp-for="Specialization" class="form-select">
                        @foreach (var item in ViewBag.Specializations)
                        {
                            <option value="@item" selected="@(Model.Specialization == item)">@item</option>
                        }
                    </select>
                </div>
                <div class="col-md-12 mb-3">
                    <label>Kinh nghiệm (năm)</label>
                    <input asp-for="YearsExperience" type="number" class="form-control" />
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Cập nhật qua Socket</button>
        </form>
    </div>
</div>