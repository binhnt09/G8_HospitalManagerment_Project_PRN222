@model G8_HospitalManagerment_Project_PRN222.Models.User

@{
    ViewData["Title"] = "Phân quyền người dùng";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white">
        <h4 class="mb-0"><i class="bi bi-shield-lock"></i> Chỉnh sửa & Phân quyền User</h4>
    </div>
    <div class="card-body p-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="UserId" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Họ</label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Tên</label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>

                <div class="col-md-12 mb-3">
                    <label class="form-label fw-bold">Email (Không được sửa)</label>
                    <input asp-for="Email" class="form-control bg-light" readonly />
                </div>

                <div class="col-md-12 mb-4">
                    <label class="form-label fw-bold text-primary">CẤP QUYỀN HỆ THỐNG</label>
                    @* Dropdown chọn Role từ DB *@
                    <select asp-for="UserRoleId" class="form-select border-primary" asp-items="ViewBag.UserRoleId"></select>
                    <span asp-validation-for="UserRoleId" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">Lưu thay đổi</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>