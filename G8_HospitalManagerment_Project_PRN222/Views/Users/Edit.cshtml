@model G8_HospitalManagerment_Project_PRN222.Models.User

@{
    ViewData["Title"] = "Chỉnh sửa Người dùng";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid py-4" style="background-color: #F8F9FA; min-height: 100vh;">
    <div class="row justify-content-center">
        <div class="col-12" style="max-width: 800px;">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h4 class="mb-0 fw-bold text-primary">Chỉnh sửa Người dùng</h4>
                    <p class="text-muted small mt-1">Cập nhật thông tin và phân quyền cho người dùng.</p>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="UserId" />
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="FirstName" class="form-label fw-medium text-dark small"></label>
                                    <input asp-for="FirstName" class="form-control rounded-3 shadow-none border-light bg-light" />
                                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="LastName" class="form-label fw-medium text-dark small"></label>
                                    <input asp-for="LastName" class="form-control rounded-3 shadow-none border-light bg-light" />
                                    <span asp-validation-for="LastName" class="text-danger small"></span>
                                </div>
                            </div>
                            
                            <div class="col-md-12">
                                <div class="form-group mb-3">
                                    <label asp-for="Email" class="form-label fw-medium text-dark small">Email (Không được sửa)</label>
                                    <input asp-for="Email" class="form-control rounded-3 shadow-none border-light bg-light" readonly />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-12">
                                <div class="form-group mb-4">
                                    <label asp-for="UserRoleId" class="form-label fw-medium text-primary small">CẤP QUYỀN HỆ THỐNG</label>
                                    <select asp-for="UserRoleId" class="form-select rounded-3 shadow-none border-primary bg-light" asp-items="ViewBag.UserRoleId"></select>
                                    <span asp-validation-for="UserRoleId" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 pt-3 border-top mt-2">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 fw-medium">
                                <i class="bi bi-arrow-left me-1"></i> Trở lại
                            </a>
                            <button type="submit" class="btn btn-primary rounded-pill px-5 fw-medium shadow-sm">
                                <i class="bi bi-save me-1"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}