@model G8_HospitalManagerment_Project_PRN222.Models.User

@{
    ViewData["Title"] = "Xóa Người dùng";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid py-4" style="background-color: #F8F9FA; min-height: 100vh;">
    <div class="row justify-content-center">
        <div class="col-12" style="max-width: 800px;">
            
            <div class="alert alert-danger shadow-sm border-0 rounded-4 mb-4" role="alert">
                <div class="d-flex align-items-center">
                    <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
                    <div>
                        <h5 class="alert-heading fw-bold mb-1">Xác nhận xóa tài khoản!</h5>
                        <p class="mb-0">Bạn có chắc chắn muốn xóa người dùng này không? Hành động này không thể hoàn tác.</p>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h4 class="mb-0 fw-bold text-dark">Thông tin Người dùng</h4>
                </div>
                
                <div class="card-body p-4">
                    <div class="row mb-4 bg-light rounded-3 p-3 mx-0">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <p class="text-muted small mb-1 fw-medium">Họ và Tên</p>
                            <h5 class="text-dark fw-bold mb-0">@Model.FirstName @Model.LastName</h5>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted small mb-1 fw-medium">Phân quyền</p>
                            @if (Model.UserRole?.RoleName == "Admin" || Model.UserRole?.RoleName == "Director")
                            {
                                <span class="badge bg-danger rounded-pill px-3">@Model.UserRole?.RoleName</span>
                            }
                            else if (Model.UserRole?.RoleName == "Doctor" || Model.UserRole?.RoleName == "Nurse")
                            {
                                <span class="badge bg-info text-dark rounded-pill px-3">@Model.UserRole?.RoleName</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill px-3">@(Model.UserRole?.RoleName ?? "N/A")</span>
                            }
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <p class="text-muted small mb-1 fw-medium">Email</p>
                            <p class="text-dark fw-medium mb-0">@(Model.Email ?? "N/A")</p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted small mb-1 fw-medium">Số điện thoại</p>
                            <p class="text-dark fw-medium mb-0">@(Model.Phone ?? "N/A")</p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted small mb-1 fw-medium">Giới tính</p>
                            <p class="text-dark fw-medium mb-0">@(Model.Gender ?? "N/A")</p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted small mb-1 fw-medium">Ngày sinh</p>
                            <p class="text-dark fw-medium mb-0">@(Model.BirthDay?.ToString("dd/MM/yyyy") ?? "N/A")</p>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white border-top-0 pb-4 px-4">
                    <form asp-action="Delete" class="d-flex justify-content-end gap-2 border-top pt-3">
                        <input type="hidden" asp-for="UserId" />
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 fw-medium">
                            <i class="bi bi-arrow-left me-1"></i> Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-danger rounded-pill px-5 fw-medium shadow-sm">
                            <i class="bi bi-trash3 me-1"></i> Xóa tài khoản
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
