@model G8_HospitalManagerment_Project_PRN222.Models.Drug

@{
    ViewData["Title"] = "Chỉnh sửa Danh mục Thuốc";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid py-4" style="background-color: #F8F9FA; min-height: 100vh;">
    <div class="card shadow-sm p-4 mx-auto border-0 rounded-4" style="max-width: 800px;">
        <div class="d-flex align-items-center mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; background-color: #fff3cd;">
                <i class="bi bi-pencil-square fs-4 text-warning"></i>
            </div>
            <h2 class="mb-0 fw-bold text-dark">Chỉnh sửa Thuốc</h2>
        </div>
        <hr class="mb-4" />

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="DrugId" />
            
            <div class="row g-3">
                <div class="col-md-12">
                    <label asp-for="DrugName" class="form-label fw-medium text-muted">Tên Thuốc <span class="text-danger">*</span></label>
                    <input asp-for="DrugName" class="form-control" required />
                    <span asp-validation-for="DrugName" class="text-danger small"></span>
                </div>
                
                <div class="col-md-4">
                    <label asp-for="Unit" class="form-label fw-medium text-muted">Đơn vị <span class="text-danger">*</span></label>
                    <input asp-for="Unit" class="form-control" required />
                    <span asp-validation-for="Unit" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Price" class="form-label fw-medium text-muted">Đơn giá (VNĐ) <span class="text-danger">*</span></label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control" required min="0" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                
                <div class="col-md-4">
                    <label asp-for="StockQuantity" class="form-label fw-medium text-muted">Số lượng Tồn kho <span class="text-danger">*</span></label>
                    <input asp-for="StockQuantity" type="number" class="form-control" required min="0" />
                    <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                </div>
                
                <div class="col-md-12">
                    <label asp-for="Description" class="form-label fw-medium text-muted">Mô tả / Hướng dẫn sử dụng</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mt-4">
                    <label asp-for="CreatedAt" class="form-label fw-medium text-muted">Ngày tạo</label>
                    <input asp-for="CreatedAt" class="form-control bg-light" readonly />
                    <span asp-validation-for="CreatedAt" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mt-4">
                    <label asp-for="UpdatedAt" class="form-label fw-medium text-muted">Ngày cập nhật</label>
                    <input asp-for="UpdatedAt" class="form-control bg-light" readonly />
                    <span asp-validation-for="UpdatedAt" class="text-danger small"></span>
                </div>
                
                <div class="col-md-6 d-flex flex-column justify-content-end">
                    <div class="form-check fs-5">
                        <input type="hidden" name="IsDeleted" value="false" />
                        <input class="form-check-input" type="checkbox" name="IsDeleted" value="true" @(Model?.IsDeleted == true ? "checked" : "") id="IsDeleted" />
                        <label class="form-check-label fw-medium text-danger" asp-for="IsDeleted" style="font-size: 0.95rem; margin-top:4px;">Đã xóa (Ngừng kinh doanh)</label>
                        <span asp-validation-for="IsDeleted" class="text-danger small d-block"></span>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-5 pt-3 border-top">
                <button type="submit" class="btn btn-primary px-4 rounded-pill fw-medium d-flex align-items-center">
                    <i class="bi bi-save me-2"></i> Lưu thay đổi
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill fw-medium d-flex align-items-center">
                    <i class="bi bi-arrow-left me-2"></i> Trở về Danh sách
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
