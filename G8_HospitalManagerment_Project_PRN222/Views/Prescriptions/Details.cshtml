@model G8_HospitalManagerment_Project_PRN222.Models.Prescription

@{
    ViewData["Title"] = $"Prescription #{Model.PrescriptionId}";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    var patientName = Model.Patient?.User != null
        ? $"{Model.Patient.User.FirstName} {Model.Patient.User.LastName}"
        : $"Patient #{Model.PatientId}";

    var doctorName = Model.Doctor?.Employee?.User != null
        ? $"Dr. {Model.Doctor.Employee.User.FirstName} {Model.Doctor.Employee.User.LastName}"
        : $"Doctor #{Model.DoctorId}";

    var activeItems = Model.PrescriptionItems.Where(pi => pi.IsDeleted != true).ToList();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    @@media print {
        .no-print { display: none !important; }
        body { background: white !important; }
        .card { box-shadow: none !important; border: 1px solid #dee2e6 !important; }
    }
</style>

@* Breadcrumb *@
<div class="no-print mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-action="Index">Prescriptions</a></li>
            <li class="breadcrumb-item active">Prescription #@Model.PrescriptionId</li>
        </ol>
    </nav>
</div>

<div class="container" style="max-width: 860px;">
    <div class="card border-0 shadow-sm p-4">

        @* ══ HEADER ══ *@
        <div class="row mb-4 align-items-center">
            <div class="col-md-7">
                <h4 class="fw-bold text-primary mb-0">
                    <i class="bi bi-hospital me-2"></i>G8 Hospital
                </h4>
                <p class="text-muted small mb-0">123 Nguyen Van Linh, Danang City, Vietnam</p>
                <p class="text-muted small">📞 (+84) 236-3999-888</p>
            </div>
            <div class="col-md-5 text-md-end">
                <h5 class="fw-bold text-uppercase text-secondary">Medical Prescription</h5>
                <p class="mb-1">
                    <span class="text-muted">Prescription No:</span>
                    <strong>#@Model.PrescriptionId</strong>
                </p>
                <p class="mb-0">
                    <span class="text-muted">Date:</span>
                    <strong>@Model.PrescriptionDate?.ToString("dd/MM/yyyy HH:mm")</strong>
                </p>
            </div>
        </div>

        <hr class="border-2" />

        @* ══ PATIENT & DOCTOR INFO ══ *@
        <div class="row mb-4 g-3">
            <div class="col-12">
                <h6 class="text-uppercase text-muted fw-semibold small mb-3">
                    <i class="bi bi-person-lines-fill me-1"></i>Patient & Doctor Information
                </h6>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100 bg-light">
                    <div class="text-muted small mb-1">Patient</div>
                    <div class="fw-semibold">@patientName</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100 bg-light">
                    <div class="text-muted small mb-1">Prescribing Doctor</div>
                    <div class="fw-semibold">@doctorName</div>
                    <div class="text-muted small">@Model.Doctor?.Specialization</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100 bg-light">
                    <div class="text-muted small mb-1">Doctor's Advice</div>
                    <div class="fw-semibold" style="font-size:0.9rem;">
                        @(string.IsNullOrWhiteSpace(Model.DoctorAdvice) ? "No advice recorded." : Model.DoctorAdvice)
                    </div>
                </div>
            </div>
        </div>

        @* ══ DRUGS TABLE ══ *@
        <h6 class="text-uppercase text-muted fw-semibold small mb-2">
            <i class="bi bi-capsule me-1"></i>Prescribed Drugs
        </h6>
        <div class="table-responsive mb-2">
            <table class="table table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th style="width:40px" class="text-center">#</th>
                        <th>Drug Name</th>
                        <th style="width:100px" class="text-center">Qty</th>
                        <th>Dosage</th>
                        <th>Duration</th>
                        <th>Usage Instructions</th>
                        @* <th class="text-center no-print" style="width:100px">Actions</th> *@
                    </tr>
                </thead>
                <tbody>
                    @if (activeItems.Any())
                    {
                        int row = 1;
                        foreach (var pi in activeItems)
                        {
                            <tr>
                                <td class="text-center text-muted">@(row++)</td>
                                <td>
                                    <div class="fw-semibold">@(pi.Drug?.DrugName ?? "Unknown Drug")</div>
                                    <div class="text-muted small">@pi.Drug?.Unit</div>
                                </td>
                                <td class="text-center fw-bold">@pi.Quantity</td>
                                <td>@(pi.Dosage ?? "—")</td>
                                <td>
                                    @if (pi.DurationDays.HasValue)
                                    {
                                        <span>@pi.DurationDays days</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>@(pi.UsageInstructions ?? "—")</td>
                                @* <td class="text-center no-print">
                                    <a asp-controller="PrescriptionItems"
                                       asp-action="Delete"
                                       asp-route-id="@pi.PrescriptionItemId"
                                       class="btn btn-sm btn-outline-danger" title="Remove item">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </td> *@
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                No drugs added yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <hr />

        @* ══ ACTION FOOTER ══ *@
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 no-print">
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-arrow-left me-1"></i> Back to List
            </a>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="PrescriptionItems"
                   asp-action="Create"
                   asp-route-prescriptionId="@Model.PrescriptionId"
                   class="btn btn-success rounded-pill px-4">
                    <i class="bi bi-plus-lg me-1"></i> Add Drug
                </a>
                <button type="button" class="btn btn-primary rounded-pill px-4" onclick="window.print()">
                    <i class="bi bi-printer me-1"></i> Print Prescription
                </button>
            </div>
        </div>

        @* ══ PRINT FOOTER ══ *@
        <div class="d-none d-print-block text-center text-muted small mt-4">
            <p class="mb-0">This prescription is only valid for <strong>7 days</strong> from the issue date.</p>
            <p class="mb-0">G8 Hospital — Computer-generated document. Doctor's digital signature verified.</p>
        </div>

    </div>
</div>
