@model G8_HospitalManagerment_Project_PRN222.Models.LabOrder

@{
    Layout = null; // Quan trọng: Tắt layout vì form này nằm trong Modal
}

<div class="px-2">
    <div class="d-flex align-items-center mb-3 border-bottom pb-2">
        <i class="bi bi-flask text-primary fs-3 me-2"></i>
        <h4 class="fw-bold text-primary mb-0">Cập nhật phiếu xét nghiệm #@Model.OrderId</h4>
    </div>

    <div class="bg-light p-3 rounded-3 mb-4 border">
        <div class="row mb-2">
            <div class="col-4 text-muted fw-semibold small">Bệnh nhân:</div>
            <div class="col-8 fw-bold text-dark">@(Model.Patient?.User?.FirstName + " " + Model.Patient?.User?.LastName ?? "Mã BN: " + Model.PatientId)</div>
        </div>
        <div class="row mb-2">
            <div class="col-4 text-muted fw-semibold small">Ngày chỉ định:</div>
            <div class="col-8">@(Model.OrderDate?.ToString("dd/MM/yyyy HH:mm"))</div>
        </div>
        <div class="row">
            <div class="col-4 text-muted fw-semibold small">Lý do/Chẩn đoán:</div>
            <div class="col-8 text-danger">@Model.Reason</div>
        </div>
    </div>

    <div class="mb-4">
        <label class="fw-bold text-dark mb-2">Danh sách Xét nghiệm (Tests)</label>
        <ul class="list-group shadow-sm">
            @if(Model.LabOrderItems != null && Model.LabOrderItems.Any())
            {
                foreach(var item in Model.LabOrderItems)
                {
                    <li class="list-group-item d-flex align-items-center py-2">
                        <i class="bi bi-droplet-half text-danger me-3 fs-5"></i> 
                        <span class="fw-medium">@(item.Test?.TestName ?? "Test ID: " + item.TestId)</span>
                    </li>
                }
            }
            else
            {
                <li class="list-group-item text-muted small">Không tìm thấy danh sách test.</li>
            }
        </ul>
    </div>

    <form asp-action="Edit" method="post">
        <input type="hidden" name="id" value="@Model.OrderId" />

        <div class="form-group mb-4">
            <label asp-for="Status" class="fw-bold text-dark mb-2">Cập nhật Trạng thái</label>
            <select asp-for="Status" class="form-select form-select-lg border-primary shadow-sm fw-medium">
                <option value="Pending">Đang chờ (Pending)</option>
                <option value="In Progress">Đang thực hiện (In Progress)</option>
                <option value="Completed">Đã hoàn thành (Completed)</option>
                <option value="Cancelled">Đã hủy (Cancelled)</option>
            </select>
            <small class="text-muted mt-1 d-block"><i class="bi bi-info-circle"></i> Trạng thái mới sẽ được đồng bộ ngay lập tức sang Hồ sơ bệnh án của Bác sĩ.</small>
        </div>

        <div class="text-end border-top pt-3 mt-4">
            <button type="button" class="btn btn-light px-4 me-2 border shadow-sm" data-bs-dismiss="modal">Đóng</button>
            <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm"><i class="bi bi-save me-2"></i>Lưu trạng thái</button>
        </div>
    </form>
</div>

@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}