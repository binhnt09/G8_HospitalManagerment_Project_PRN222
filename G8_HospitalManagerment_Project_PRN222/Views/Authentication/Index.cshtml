@model G8_HospitalManagerment_Project_PRN222.Models.ViewModels.RegisterViewModel
@{
    var mode = ViewBag.Mode ?? "login";
    ViewData["Title"] = (mode == "register") ? "Tham gia ChildrenCare" : "Chào mừng trở lại";
    Layout = null;
}
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-blue: #0077b6;
            --secondary-cyan: #00b4d8;
            --bg-gradient-start: #e0f7fa;
            --bg-gradient-end: #80deea;
            --text-dark: #2b2d42;
            --text-muted: #8d99ae;
        }

        body {
            /* Nền sáng, nhẹ nhàng hơn cho chủ đề sức khỏe/trẻ em */
            background: linear-gradient(135deg, var(--bg-gradient-start) 0%, var(--bg-gradient-end) 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 15px;
            font-family: 'Quicksand', sans-serif;
            color: var(--text-dark);
            position: relative;
        }

        /* Nút quay lại trang chủ góc trái */
        .btn-home {
            position: absolute;
            top: 20px;
            left: 20px;
            color: var(--primary-blue);
            text-decoration: none;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 15px;
            background: rgba(255, 255, 255, 0.7);
            border-radius: 50px;
            backdrop-filter: blur(5px);
            transition: all 0.3s ease;
        }

            .btn-home:hover {
                background: white;
                color: var(--secondary-cyan);
                box-shadow: 0 4px 15px rgba(0,0,0,0.05);
                transform: translateX(-3px);
            }

        .auth-card {
            background: #ffffff;
            border-radius: 24px;
            box-shadow: 0 15px 35px rgba(0, 119, 182, 0.1);
            width: 100%;
            max-width: @(mode == "register" ? "850px" : "450px");
            transition: max-width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
            position: relative;
        }

        .tab-header {
            display: flex;
            background: #f8fbfd;
            border-bottom: 1px solid #edf2f7;
        }

        .tab-link {
            flex: 1;
            padding: 18px;
            text-align: center;
            text-decoration: none;
            font-weight: 700;
            color: var(--text-muted);
            transition: all 0.3s ease;
            font-size: 1.05rem;
            position: relative;
        }

            .tab-link:hover {
                color: var(--secondary-cyan);
            }

            .tab-link.active {
                color: var(--primary-blue);
                background: white;
            }

                .tab-link.active::after {
                    content: '';
                    position: absolute;
                    bottom: -1px;
                    left: 0;
                    width: 100%;
                    height: 3px;
                    background: var(--primary-blue);
                    border-radius: 3px 3px 0 0;
                }

        .form-container {
            padding: 40px;
            animation: fadeIn 0.5s ease;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .brand-logo {
            font-weight: 800;
            color: var(--primary-blue);
            font-size: 1.8rem;
            margin-bottom: 1.5rem;
        }

            .brand-logo i {
                color: var(--secondary-cyan);
            }

        /* Style cho Input */
        .form-label {
            font-weight: 600;
            color: var(--text-dark);
            margin-bottom: 6px;
        }

        .input-group {
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #e2e8f0;
            transition: all 0.3s ease;
            background: #f8fafc;
        }

            .input-group:focus-within {
                border-color: var(--secondary-cyan);
                box-shadow: 0 0 0 3px rgba(0, 180, 216, 0.15);
                background: #ffffff;
            }

        .input-group-text {
            background: transparent;
            border: none;
            color: var(--text-muted);
            padding-left: 15px;
        }

        .input-group:focus-within .input-group-text {
            color: var(--primary-blue);
        }

        .form-control, .form-select {
            border: none;
            background: transparent;
            padding: 12px 15px;
            font-weight: 500;
        }

            .form-control:focus, .form-select:focus {
                box-shadow: none;
                background: transparent;
            }

        /* Khi không dùng input-group (bên form đăng ký) */
        .form-control-alone {
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            background: #f8fafc;
            padding: 12px 15px;
            transition: all 0.3s ease;
            font-weight: 500;
        }

            .form-control-alone:focus {
                border-color: var(--secondary-cyan);
                box-shadow: 0 0 0 3px rgba(0, 180, 216, 0.15);
                background: #ffffff;
            }

        /* Các nút bấm */
        .btn-submit {
            background: linear-gradient(135deg, var(--primary-blue), var(--secondary-cyan));
            color: white;
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 700;
            font-size: 1.1rem;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
        }

            .btn-submit:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0, 180, 216, 0.3);
                color: white;
            }

        .btn-google {
            background: #ffffff;
            color: #3c4043;
            border: 1px solid #dadce0;
            border-radius: 12px;
            padding: 12px;
            font-weight: 600;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            text-decoration: none;
        }

            .btn-google img {
                width: 20px;
                height: 20px;
            }

            .btn-google:hover {
                background: #f8f9fa;
                border-color: #d2e3fc;
                box-shadow: 0 4px 10px rgba(0,0,0,0.05);
                color: #3c4043;
            }

        .forgot-password {
            color: var(--primary-blue);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: 0.3s;
        }

            .forgot-password:hover {
                color: var(--secondary-cyan);
                text-decoration: underline;
            }

        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            color: var(--text-muted);
            margin: 1.5rem 0;
            font-size: 0.9rem;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                border-bottom: 1px solid #e2e8f0;
            }

            .divider:not(:empty)::before {
                margin-right: .5em;
            }

            .divider:not(:empty)::after {
                margin-left: .5em;
            }

        /* Mobile Responsive */
        @@media (max-width: 768px) {
            .form-container {
                padding: 25px 20px;
            }
        }
    </style>
</head>
<body>
    <a asp-area="" asp-controller="Home" asp-action="Index" class="btn-home">
        <i class="fas fa-arrow-left"></i> Trang chủ
    </a>

    <div class="auth-card">
        <div class="tab-header">
            <a asp-controller="Authentication"
               asp-action="Login"
               class="tab-link @(mode == "login" ? "active" : "")">
                ĐĂNG NHẬP
            </a>

            <a asp-controller="Authentication"
               asp-action="Register"
               class="tab-link @(mode == "register" ? "active" : "")">
                ĐĂNG KÝ
            </a>
        </div>

        <div class="form-container">
            <div class="text-center">
                <div class="brand-logo">
                    <i class="fas fa-hand-holding-heart"></i> ChildrenCare
                </div>
                <p class="text-muted mb-4">
                    @(mode == "login" ? "Vui lòng đăng nhập để tiếp tục." : "Tạo tài khoản để trải nghiệm dịch vụ.")
                </p>
            </div>

            @if (mode == "login")
            {
                @* Thông báo thành công sau khi Resend *@
                @if (TempData["ResendSuccess"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4">
                        <i class="fas fa-check-circle me-2"></i> @TempData["ResendSuccess"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @* Thông báo lỗi Login *@
                @if (ViewBag.LoginError != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            <span>
                                @ViewBag.LoginError
                                @if (ViewBag.ShowResend == true)
                                {
                                    <form asp-action="ResendVerifyEmail" method="post" class="d-inline ms-2">
                                        <input type="hidden" name="email" value="@ViewBag.UnverifiedEmail" />
                                        <button type="submit" class="btn btn-link p-0 text-danger fw-bold text-decoration-underline" style="font-size: 0.9rem;">
                                            Gửi lại mail?
                                        </button>
                                    </form>
                                }
                            </span>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form method="post" asp-action="Login">
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="example@gmail.com" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mật khẩu</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required />
                        </div>
                    </div>

                    <div class="text-end mb-4">
                        <a asp-action="ForgotPassword" class="forgot-password">Quên mật khẩu?</a>
                    </div>

                    <button type="submit" class="btn btn-submit w-100 mb-3">ĐĂNG NHẬP NGAY</button>

                    <div class="divider">HOẶC</div>

                    <a asp-action="LoginGoogle" asp-controller="Authentication" class="btn-google">
                        <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google Logo">
                        Đăng nhập bằng Google
                    </a>
                </form>
            }
            else
            {
                <div class="register-form-wrapper">


                    <form method="post" asp-action="Register">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Họ (Last Name)</label>
                                <input asp-for="LastName" class="form-control form-control-alone" placeholder="Nguyễn" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Tên (First Name)</label>
                                <input asp-for="FirstName" class="form-control form-control-alone" placeholder="Văn A" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Email</label>
                                <input asp-for="Email" type="email" class="form-control form-control-alone" placeholder="example@gmail.com" />
                                <span asp-validation-for="Email" class="text-danger d-block mt-1 small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Mật khẩu</label>
                                <input asp-for="Password" type="password" class="form-control form-control-alone" />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Xác nhận mật khẩu</label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control form-control-alone" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Số điện thoại</label>
                                <input asp-for="Phone" class="form-control form-control-alone" placeholder="09xx xxx xxx" />
                                <span asp-validation-for="Phone" class="text-danger d-block mt-1 small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Giới tính</label>
                                <select asp-for="Gender" class="form-select form-control-alone">
                                    <option value="Nữ">Nữ</option>
                                    <option value="Nam">Nam</option>
                                    <option value="Khác">Khác</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label class="form-label">Ngày sinh</label>
                                <input asp-for="BirthDay" type="date" class="form-control form-control-alone" />
                                <span asp-validation-for="BirthDay" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Địa chỉ</label>
                                <input asp-for="Address" class="form-control form-control-alone" placeholder="Số nhà, tên đường, quận/huyện..." />
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mt-4">
                                <button type="submit" class="btn btn-submit w-100 shadow">TẠO TÀI KHOẢN</button>
                            </div>
                        </div>
                    </form>
                </div>
            }
        </div>
    </div>

</body>
</html>