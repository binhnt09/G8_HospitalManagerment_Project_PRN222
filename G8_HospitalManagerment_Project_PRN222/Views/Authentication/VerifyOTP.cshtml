@{
    ViewData["Title"] = "Xác thực OTP";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <div class="mb-3">
                        <i class="bi bi-shield-lock text-primary" style="font-size: 3rem;"></i>
                    </div>
                    <h3>Xác thực OTP</h3>
                    <p class="text-muted small">
                        Mã xác thực đã được gửi đến email: <br />
                        <strong>@Context.Session.GetString("ResetEmail")</strong>
                    </p>

                    <form asp-action="VerifyOTP" method="post" class="mt-4">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <input type="text" name="otp" class="form-control form-control-lg text-center fw-bold" 
                                   placeholder="000000" maxlength="6" pattern="\d{6}" 
                                   style="letter-spacing: 0.5rem;" required autofocus />
                        </div>

                        @if (ViewBag.Error != null)
                        {
                            <div class="text-danger small mb-3">@ViewBag.Error</div>
                        }

                        <button type="submit" class="btn btn-success w-100 py-2">Xác nhận mã</button>
                    </form>

                    <p class="mt-3 small text-muted">
                        Không nhận được mã? 
                        <a asp-action="ForgotPassword" class="text-decoration-none">Gửi lại</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>