@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = null; // Hoặc Layout của bạn
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="container d-flex align-items-center justify-content-center" style="min-height: 100vh;">
    <div class="card shadow-lg border-0 p-4" style="max-width: 450px; width: 100%; border-radius: 20px;">
        <h3 class="text-center fw-bold mb-4" style="color: #0077b6;">Quên mật khẩu?</h3>

        @if (TempData["Error"] != null)
        {
            <div class="alert @(TempData["IsGoogleOnly"] != null ? "alert-info" : "alert-danger")">
                @TempData["Error"]
            </div>
        }

        @if (TempData["IsGoogleOnly"] != null)
        {
            <a asp-action="LoginGoogle" class="btn btn-outline-dark w-100 mb-3">
                Đăng nhập bằng Google
            </a>
        }

        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning">
                @TempData["Warning"]
            </div>
        }

        <p class="text-muted text-center small mb-4">Nhập email của bạn để tiếp tục quy trình khôi phục mật khẩu.</p>

        <form method="post" asp-action="ForgotPassword" asp-controller="Authentication">
            @* QUAN TRỌNG: AntiforgeryToken để tránh lỗi 400 *@
            @Html.AntiForgeryToken()

            <div class="mb-4">
                <label class="form-label fw-bold">Địa chỉ Email</label>
                <div class="input-group border rounded-3 overflow-hidden">
                    <span class="input-group-text bg-light border-0">
                        <i class="fas fa-envelope text-muted"></i>
                    </span>
                    <input name="email"
                           type="email"
                           class="form-control border-0"
                           placeholder="example@gmail.com"
                           value="@TempData.Peek("EnteredEmail")"
                           required />
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius: 12px; background: #00b4d8; border: none;">
                TIẾP TỤC
            </button>

            <div class="text-center mt-4">
                <a asp-action="Login" class="text-decoration-none fw-bold" style="color: #0077b6;">Quay lại Đăng nhập</a>
            </div>
        </form>
    </div>
</div>