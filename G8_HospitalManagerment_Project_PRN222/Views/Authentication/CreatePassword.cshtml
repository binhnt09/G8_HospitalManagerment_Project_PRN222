@model G8_HospitalManagerment_Project_PRN222.Models.ViewModels.SetPasswordViewModel

@{
    ViewData["Title"] = "Thiết lập mật khẩu";
    Layout = null; // Hoặc Layout chung của bạn
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
    body {
        background: linear-gradient(135deg, #e0f7fa 0%, #80deea 100%);
        font-family: 'Quicksand', sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .setup-card {
        background: white;
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(0, 119, 182, 0.1);
        width: 100%;
        max-width: 450px;
        padding: 40px;
    }

    .btn-submit {
        background: linear-gradient(135deg, #0077b6, #00b4d8);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px;
        font-weight: 700;
        transition: all 0.3s ease;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 180, 216, 0.3);
            color: white;
        }

    .form-control {
        border-radius: 12px;
        padding: 12px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
    }
</style>

<div class="setup-card">
    <div class="text-center mb-4">
        <div style="font-size: 3rem; color: #00b4d8;">
            <i class="fas fa-shield-alt"></i>
        </div>
        <h3 class="fw-bold mt-3">Thiết lập mật khẩu</h3>
        <p class="text-muted small">Tạo mật khẩu để bạn có thể đăng nhập bằng Email thay vì chỉ dùng Google.</p>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger small">
            <ul class="mb-0">
                @foreach (var modelError in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@modelError.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form asp-action="CreatePassword" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label fw-600">Mật khẩu mới</label>
            <div class="input-group">
                <input asp-for="NewPassword" type="password" class="form-control" placeholder="Nhập mật khẩu ít nhất 6 ký tự" />
            </div>
            <span asp-validation-for="NewPassword" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label class="form-label fw-600">Xác nhận mật khẩu</label>
            <div class="input-group">
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu" />
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-submit w-100 mb-3">HOÀN TẤT THIẾT LẬP</button>

        <div class="text-center">
            <a asp-controller="Users" asp-action="Profile" class="text-decoration-none text-muted small">
                <i class="fas fa-arrow-left me-1"></i> Quay lại hồ sơ
            </a>
        </div>
    </form>
</div>