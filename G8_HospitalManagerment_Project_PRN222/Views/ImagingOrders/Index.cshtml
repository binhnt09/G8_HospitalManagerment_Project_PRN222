@model IEnumerable<G8_HospitalManagerment_Project_PRN222.Models.ImagingOrder>

@{
    ViewData["Title"] = "Quản lý chẩn đoán hình ảnh";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container-fluid py-4" style="background-color: #F8F9FA; min-height: 100vh;">
    
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        
        <form id="searchForm" asp-action="Index" method="get" class="d-flex flex-grow-1" style="max-width: 500px;">
            <div class="input-group shadow-sm rounded-pill overflow-hidden bg-white border-0">
                <span class="input-group-text bg-transparent border-0 text-muted ps-4">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" name="searchString" value="@ViewBag.CurrentFilter" class="form-control border-0 shadow-none bg-transparent" placeholder="Tìm theo Lý do, Bác sĩ, Bệnh nhân..." aria-label="Search">
                <button class="btn btn-primary rounded-pill m-1 px-4 fw-medium" type="submit">Search</button>
            </div>
            <input type="hidden" name="sortOrder" value="@ViewBag.CurrentSort" />
            <input type="hidden" name="filterStatus" value="@ViewBag.CurrentStatusFilter" />
        </form>

        <div class="d-flex gap-2 flex-wrap">
            
            <div class="dropdown shadow-sm rounded-pill">
                <button class="btn btn-white bg-white border-0 rounded-pill px-4 py-2 d-flex align-items-center gap-2 fw-medium text-dark" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-funnel text-warning"></i> 
                    @(ViewBag.CurrentStatusFilter == "Today" ? "Chỉ định hôm nay" : 
                      ViewBag.CurrentStatusFilter == "Pending" ? "Đang chờ (Pending)" : 
                      ViewBag.CurrentStatusFilter == "Completed" ? "Đã xong (Completed)" : "Lọc trạng thái")
                </button>
                <ul class="dropdown-menu border-0 shadow-sm rounded-3 mt-2">
                    <li><a class="dropdown-item py-2 ajax-link" asp-action="Index" asp-route-filterStatus="" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-searchString="@ViewBag.CurrentFilter">Tất cả</a></li>
                    <li><a class="dropdown-item py-2 ajax-link" asp-action="Index" asp-route-filterStatus="Today" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-calendar-day me-2 text-primary"></i>Hôm nay</a></li>
                    <li><a class="dropdown-item py-2 ajax-link" asp-action="Index" asp-route-filterStatus="Pending" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-hourglass-split me-2 text-warning"></i>Đang chờ (Pending)</a></li>
                    <li><a class="dropdown-item py-2 ajax-link" asp-action="Index" asp-route-filterStatus="Completed" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-check-circle me-2 text-success"></i>Đã xong (Completed)</a></li>
                </ul>
            </div>

            <div class="dropdown shadow-sm rounded-pill">
                <button class="btn btn-white bg-white border-0 rounded-pill px-4 py-2 d-flex align-items-center gap-2 fw-medium text-dark" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-sort-down text-primary"></i> Sort By
                </button>
                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm rounded-3 mt-2">
                    <li><a class="dropdown-item py-2 ajax-link" asp-action="Index" asp-route-sortOrder="@ViewBag.DateSortParm" asp-route-filterStatus="@ViewBag.CurrentStatusFilter" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-calendar-event me-2 text-muted"></i>Order Date</a></li>
                    <li><a class="dropdown-item py-2 ajax-link" asp-action="Index" asp-route-sortOrder="doctor_asc" asp-route-filterStatus="@ViewBag.CurrentStatusFilter" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-person-badge me-2 text-muted"></i>Doctor Name</a></li>
                    <li><a class="dropdown-item py-2 ajax-link" asp-action="Index" asp-route-sortOrder="status_asc" asp-route-filterStatus="@ViewBag.CurrentStatusFilter" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-circle-half me-2 text-muted"></i>Status</a></li>
                </ul>
            </div>
            
            <a asp-action="Create" class="open-modal-btn btn btn-primary rounded-pill px-4 py-2 d-flex align-items-center gap-2 fw-medium shadow-sm">
                <i class="bi bi-plus-lg"></i> New Order
            </a>
        </div>
    </div>
    
    <div id="order-grid-container" style="transition: all 0.3s ease;">
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" style="font-size: 0.95rem;">
                        <thead class="text-muted" style="background-color: #FAFAFA; font-size: 0.85rem; text-transform: uppercase;">
                            <tr>
                                <th class="ps-4 py-3 border-bottom-0 fw-semibold">
                                    <a asp-action="Index" asp-route-sortOrder="@ViewBag.DateSortParm" asp-route-filterStatus="@ViewBag.CurrentStatusFilter" asp-route-searchString="@ViewBag.CurrentFilter" class="text-decoration-none text-muted ajax-link">
                                        Order Date <i class="bi bi-arrow-down-up ms-1"></i>
                                    </a>
                                </th>
                                <th class="py-3 border-bottom-0 fw-semibold">Service</th>
                                <th class="py-3 border-bottom-0 fw-semibold">Doctor</th>
                                <th class="py-3 border-bottom-0 fw-semibold">Patient</th>
                                <th class="py-3 border-bottom-0 fw-semibold">Status</th>
                                <th class="py-3 border-bottom-0 fw-semibold">Record Status</th>
                                <th class="pe-4 py-3 border-bottom-0 fw-semibold text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="border-top-0">
                            @if(!Model.Any())
                            {
                                <tr><td colspan="7" class="text-center py-5 text-muted">No Image orders found.</td></tr>
                            }
                            @foreach (var item in Model) {
                                <tr>
                                    <td class="ps-4 py-3">
                                        <div class="fw-bold text-dark">@item.OrderDate?.ToString("yyyy-MM-dd")</div>
                                        <div class="text-muted small">@item.OrderDate?.ToString("HH:mm")</div>
                                    </td>
                                    <td class="py-3">
                                        <div class="text-dark">@item.Service.ServiceName</div>
                                        <div class="text-muted small">Record: @item.MedicalRecord?.RecordId</div>
                                    </td>
                                    <td class="py-3">
                                        <div class="fw-bold text-dark">Dr. @(item.Doctor?.DoctorId)</div>
                                    </td>
                                    <td class="py-3">
                                        <div class="fw-bold text-dark">@(item.Patient?.User?.FirstName + " " + item.Patient?.User?.LastName)</div>
                                        <div class="text-muted small">Mã BN: @item.Patient?.PatientId</div>
                                    </td>
                                    <td class="py-3">
                                        @if(item.Status == "Completed") {
                                            <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2">Completed</span>
                                        } else if(item.Status == "Pending") {
                                            <span class="badge bg-warning-subtle text-warning rounded-pill px-3 py-2">Pending</span>
                                        } else if(item.Status == "In Progress") {
                                            <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">In Progress</span>
                                        } else {
                                            <span class="badge bg-danger-subtle text-danger rounded-pill px-3 py-2">Cancelled</span>
                                        }
                                    </td>
                                    <td class="py-3">
                                        @if(item.IsDeleted == true) {
                                            <span class="badge bg-danger-subtle text-danger rounded-pill px-3 py-2">Deleted</span>
                                        } else {
                                            <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2">Active</span>
                                        }
                                    </td>
                                    <td class="pe-4 py-3 text-end">
                                        <a asp-action="Details" asp-route-id="@item.OrderId" class="open-modal-btn btn btn-sm btn-light text-muted p-2 rounded-circle me-1"><i class="bi bi-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@item.OrderId" class="open-modal-btn btn btn-sm btn-light text-primary p-2 rounded-circle me-1"><i class="bi bi-pencil-square"></i></a>
                                        <div class="dropdown d-inline">
                                            <button class="btn btn-sm btn-light text-muted p-2 rounded-circle" type="button" data-bs-toggle="dropdown">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-1">
                                                <li><a class="open-modal-btn dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.OrderId"><i class="bi bi-trash3 me-2"></i>Delete</a></li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center p-4 border-top">
                    <div class="text-muted" style="font-size: 0.9rem;">
                        Showing <span class="fw-bold text-dark">@ViewBag.ItemStart</span> to <span class="fw-bold text-dark">@ViewBag.ItemEnd</span> of <span class="fw-bold text-dark">@ViewBag.TotalItems</span> orders
                    </div>
                    
                    @if (totalPages > 1)
                    {
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link rounded-pill border-0 text-muted px-3 ajax-link" asp-action="Index" asp-route-pageNumber="@(currentPage - 1)" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-filterStatus="@ViewBag.CurrentStatusFilter" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-chevron-left me-1"></i> Previous</a>
                            </li>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link rounded-circle border-0 mx-1 ajax-link @(i == currentPage ? "bg-primary text-white" : "text-dark")" asp-action="Index" asp-route-pageNumber="@i" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-filterStatus="@ViewBag.CurrentStatusFilter" asp-route-searchString="@ViewBag.CurrentFilter">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link rounded-pill border-0 text-muted px-3 ajax-link" asp-action="Index" asp-route-pageNumber="@(currentPage + 1)" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-filterStatus="@ViewBag.CurrentStatusFilter" asp-route-searchString="@ViewBag.CurrentFilter">Next <i class="bi bi-chevron-right ms-1"></i></a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div> <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted mb-1" style="font-size: 0.9rem;">Total Orders</div>
                        <h3 class="fw-bold mb-0 text-dark">@ViewBag.TotalOrders</h3>
                    </div>
                    <div class="rounded-circle d-flex justify-content-center align-items-center" style="width: 50px; height: 50px; background-color: #E8F0FE; color: #1A73E8;">
                        <i class="bi bi-file-earmark-text fs-5"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted mb-1" style="font-size: 0.9rem;">Completed</div>
                        <h3 class="fw-bold mb-0 text-success">@ViewBag.CompletedCount</h3>
                    </div>
                    <div class="rounded-circle d-flex justify-content-center align-items-center" style="width: 50px; height: 50px; background-color: #E6F4EA; color: #1E8E3E;">
                        <i class="bi bi-check-lg fs-5"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted mb-1" style="font-size: 0.9rem;">Pending</div>
                        <h3 class="fw-bold mb-0 text-warning" style="color: #F9AB00 !important;">@ViewBag.PendingCount</h3>
                    </div>
                    <div class="rounded-circle d-flex justify-content-center align-items-center" style="width: 50px; height: 50px; background-color: #FEF7E0; color: #F9AB00;">
                        <i class="bi bi-clock-history fs-5"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted mb-1" style="font-size: 0.9rem;">Active</div>
                        <h3 class="fw-bold mb-0 text-primary">@ViewBag.ActiveCount</h3>
                    </div>
                    <div class="rounded-circle d-flex justify-content-center align-items-center" style="width: 50px; height: 50px; background-color: #E8F0FE; color: #1A73E8;">
                        <i class="bi bi-lightning-charge fs-5"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="formModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg"> 
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-bottom-0 pb-0">
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body pt-0 px-4 pb-4" id="modal-body-content">
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-muted">Loading...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            
            // XỬ LÝ MỞ MODAL (GIỮ NGUYÊN CỦA BẠN)
            $(document).on('click', '.open-modal-btn', function (e) {
                e.preventDefault(); 
                var url = $(this).attr('href'); 
                $('#modal-body-content').html('<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div><p class="mt-2 text-muted">Loading...</p></div>');
                $('#formModal').modal('show');
                $.get(url, function (data) {
                    $('#modal-body-content').html(data);
                }).fail(function() {
                    $('#modal-body-content').html('<div class="alert alert-danger">Error loading data. Please try again.</div>');
                });
            });

            // XỬ LÝ AJAX LỌC, TÌM KIẾM, PHÂN TRANG MƯỢT MÀ
            function loadGridData(url) {
                $('#order-grid-container').css('opacity', '0.4');
                $('#order-grid-container').load(url + ' #order-grid-container > *', function (response, status, xhr) {
                    if (status == "error") {
                        alert("Lỗi tải dữ liệu. Vui lòng thử lại!");
                    }
                    $('#order-grid-container').css('opacity', '1');
                });
            }

            // Tìm kiếm
            $('#searchForm').on('submit', function (e) {
                e.preventDefault();
                var url = $(this).attr('action') + '?' + $(this).serialize(); 
                loadGridData(url);
            });

            // Phân trang & Lọc & Sắp xếp
            $(document).on('click', '.ajax-link', function (e) {
                e.preventDefault(); 
                var url = $(this).attr('href');
                
                // Giữ lại từ khóa tìm kiếm khi bấm lọc
                var searchVal = $('input[name="searchString"]').val();
                if(searchVal && !url.includes('searchString=')) {
                    url += (url.includes('?') ? '&' : '?') + 'searchString=' + encodeURIComponent(searchVal);
                }
                loadGridData(url);
            });
        });
    </script>
}