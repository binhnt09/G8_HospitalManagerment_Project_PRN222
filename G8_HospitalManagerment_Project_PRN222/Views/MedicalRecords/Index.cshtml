@model IEnumerable<G8_HospitalManagerment_Project_PRN222.Models.MedicalRecord>

@{
    ViewData["Title"] = "Quản lý Hồ sơ Khám bệnh";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container-fluid py-4" style="background-color: #F8F9FA; min-height: 100vh;">
    
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        
        <form id="searchForm" asp-action="Index" method="get" class="d-flex flex-grow-1" style="max-width: 450px;">
            <div class="input-group shadow-sm rounded-pill overflow-hidden bg-white border-0">
                <span class="input-group-text bg-transparent border-0 text-muted ps-4">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" name="searchString" value="@ViewBag.CurrentFilter" class="form-control border-0 shadow-none bg-transparent" placeholder="Tìm tên BN, chẩn đoán, triệu chứng..." aria-label="Search">
                <button class="btn btn-primary rounded-pill m-1 px-4 fw-medium" type="submit">Tìm</button>
            </div>
            <input type="hidden" name="sortOrder" value="@ViewBag.CurrentSort" />
            <input type="hidden" name="filterStatus" value="@ViewBag.CurrentStatusFilter" />
        </form>

        <div class="d-flex gap-2 flex-wrap">
            
            <div class="dropdown shadow-sm rounded-pill">
                <button class="btn btn-white bg-white border-0 rounded-pill px-4 py-2 d-flex align-items-center gap-2 fw-medium text-dark" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-funnel text-warning"></i> 
                    @(ViewBag.CurrentStatusFilter == "Today" ? "Khám hôm nay" : 
                      ViewBag.CurrentStatusFilter == "PendingCLS" ? "Đang chờ kết quả" : 
                      ViewBag.CurrentStatusFilter == "CompletedCLS" ? "Đã có kết quả" : "Lọc trạng thái")
                </button>
                <ul class="dropdown-menu border-0 shadow-sm rounded-3 mt-2">
                    <li><a class="dropdown-item py-2 ajax-link" asp-action="Index" asp-route-filterStatus="" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-searchString="@ViewBag.CurrentFilter">Tất cả hồ sơ</a></li>
                    <li><a class="dropdown-item py-2 ajax-link" asp-action="Index" asp-route-filterStatus="Today" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-calendar-day me-2 text-primary"></i>Khám hôm nay</a></li>
                    <li><a class="dropdown-item py-2 ajax-link" asp-action="Index" asp-route-filterStatus="PendingCLS" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-hourglass-split me-2 text-warning"></i>Đang chờ kết quả CLS</a></li>
                    <li><a class="dropdown-item py-2 ajax-link" asp-action="Index" asp-route-filterStatus="CompletedCLS" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-check-circle me-2 text-success"></i>Đã có kết quả CLS</a></li>
                </ul>
            </div>

            <div class="dropdown shadow-sm rounded-pill">
                <button class="btn btn-white bg-white border-0 rounded-pill px-4 py-2 d-flex align-items-center gap-2 fw-medium text-dark" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-sort-down text-primary"></i> Sắp xếp
                </button>
                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm rounded-3 mt-2">
                    <li><a class="dropdown-item py-2 ajax-link" asp-action="Index" asp-route-sortOrder="@ViewBag.DateSortParm" asp-route-filterStatus="@ViewBag.CurrentStatusFilter" asp-route-searchString="@ViewBag.CurrentFilter">Ngày khám</a></li>
                    <li><a class="dropdown-item py-2 ajax-link" asp-action="Index" asp-route-sortOrder="@ViewBag.NameSortParm" asp-route-filterStatus="@ViewBag.CurrentStatusFilter" asp-route-searchString="@ViewBag.CurrentFilter">Tên bệnh nhân</a></li>
                </ul>
            </div>
            
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 py-2 d-flex align-items-center gap-2 fw-medium shadow-sm">
                <i class="bi bi-plus-lg"></i> Tạo hồ sơ
            </a>
        </div>
    </div>
    <div id="record-grid-container" style="transition: all 0.3s ease;">
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" style="font-size: 0.95rem;">
                        <thead class="text-muted" style="background-color: #FAFAFA; font-size: 0.85rem; text-transform: uppercase;">
                            <tr>
                                <th class="ps-4 py-3 border-bottom-0 fw-semibold">Ngày khám</th>
                                <th class="py-3 border-bottom-0 fw-semibold">Bệnh nhân</th>
                                <th class="py-3 border-bottom-0 fw-semibold" style="max-width: 250px;">Lâm sàng</th>
                                <th class="py-3 border-bottom-0 fw-semibold text-center">Trạng thái Cận Lâm Sàng</th>
                                <th class="py-3 border-bottom-0 fw-semibold">Hướng điều trị</th>
                                <th class="pe-4 py-3 border-bottom-0 fw-semibold text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody class="border-top-0">
                            @if(!Model.Any())
                            {
                                <tr><td colspan="6" class="text-center py-5 text-muted">Không tìm thấy hồ sơ nào.</td></tr>
                            }
                            @foreach (var item in Model) {
                                // Logic tính toán trạng thái CLS hiển thị
                                bool hasLab = item.LabOrders != null && item.LabOrders.Any();
                                bool pendingLab = hasLab && item.LabOrders.Any(l => l.Status == "Pending");

                                bool hasImg = item.ImagingOrders != null && item.ImagingOrders.Any();
                                bool pendingImg = hasImg && item.ImagingOrders.Any(i => i.Status == "Pending");

                                <tr>
                                    <td class="ps-4 py-3">
                                        <div class="fw-bold text-dark">@item.RecordDate?.ToString("dd/MM/yyyy")</div>
                                        <div class="text-muted small">@item.RecordDate?.ToString("HH:mm")</div>
                                    </td>
                                    
                                    <td class="py-3">
                                        <div class="fw-bold text-dark">@(item.Patient?.User?.FirstName + " " + item.Patient?.User?.LastName)</div>
                                        <div class="text-muted small">Mã BN: @item.PatientId</div>
                                    </td>

                                    <td class="py-3" style="max-width: 250px;">
                                        <div class="text-danger fw-semibold text-truncate" title="@item.Diagnosis">@item.Diagnosis</div>
                                        <div class="text-muted small text-truncate" title="@item.Symptoms">@item.Symptoms</div>
                                    </td>

                                    <td class="py-3 text-center">
                                        <div class="d-flex flex-column gap-1 align-items-center">
                                            @if (hasLab)
                                            {
                                                if (pendingLab) { <span class="badge bg-warning-subtle text-warning rounded-pill" style="width: 110px;">Xét nghiệm: Chờ</span> }
                                                else { <span class="badge bg-success-subtle text-success rounded-pill" style="width: 110px;">Xét nghiệm: Xong</span> }
                                            }
                                            
                                            @if (hasImg)
                                            {
                                                if (pendingImg) { <span class="badge bg-warning-subtle text-warning rounded-pill" style="width: 110px;">CĐHA: Chờ</span> }
                                                else { <span class="badge bg-success-subtle text-success rounded-pill" style="width: 110px;">CĐHA: Xong</span> }
                                            }

                                            @if (!hasLab && !hasImg)
                                            {
                                                <span class="badge bg-light text-secondary border rounded-pill">Không chỉ định</span>
                                            }
                                        </div>
                                    </td>

                                    <td class="py-3">
                                        <div class="text-dark text-truncate" style="max-width: 200px;" title="@item.Treatment">
                                            @(string.IsNullOrEmpty(item.Treatment) ? "Chưa có" : item.Treatment)
                                        </div>
                                    </td>

                                    <td class="pe-4 py-3 text-end">
                                        <div class="d-flex justify-content-end gap-1">
                                            <a asp-action="Details" asp-route-id="@item.RecordId" class="btn btn-sm btn-light text-muted p-2 rounded-circle" title="Xem chi tiết"><i class="bi bi-eye"></i></a>
                                            <a asp-action="Edit" asp-route-id="@item.RecordId" class="open-modal-btn btn btn-sm btn-light text-primary p-2 rounded-circle me-1" title="Khám lần 2 / Chốt bệnh"><i class="bi bi-pencil-square"></i></a>
                                            
                                            <div class="dropdown d-inline">
                                                <button class="btn btn-sm btn-light text-muted p-2 rounded-circle" type="button" data-bs-toggle="dropdown">
                                                    <i class="bi bi-three-dots-vertical"></i>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-1">
                                                    <li>
                                                        <a class="dropdown-item py-2" asp-controller="Invoices" asp-action="GenerateInvoice" asp-route-appointmentId="@item.AppointmentId">
                                                            <i class="bi bi-receipt me-2 text-info"></i>Xuất hóa đơn
                                                        </a>
                                                    </li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li><a class="dropdown-item text-danger py-2" asp-action="Delete" asp-route-id="@item.RecordId"><i class="bi bi-trash3 me-2"></i>Xóa hồ sơ</a></li>
                                                </ul>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex flex-column flex-md-row justify-content-between align-items-center p-4 border-top">
                    <div class="text-muted small mb-3 mb-md-0">
                        Hiển thị <span class="fw-bold text-dark">@ViewBag.ItemStart</span> - <span class="fw-bold text-dark">@ViewBag.ItemEnd</span> trong tổng số <span class="fw-bold text-dark">@ViewBag.TotalItems</span> hồ sơ
                    </div>
                    
                    @if (totalPages > 1)
                    {
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link rounded-pill border-0 text-muted px-3 ajax-link" asp-action="Index" asp-route-pageNumber="@(currentPage - 1)" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-filterStatus="@ViewBag.CurrentStatusFilter" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-chevron-left me-1"></i> Trước</a>
                            </li>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link rounded-circle border-0 mx-1 ajax-link @(i == currentPage ? "bg-primary text-white" : "text-dark")" asp-action="Index" asp-route-pageNumber="@i" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-filterStatus="@ViewBag.CurrentStatusFilter" asp-route-searchString="@ViewBag.CurrentFilter">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link rounded-pill border-0 text-muted px-3 ajax-link" asp-action="Index" asp-route-pageNumber="@(currentPage + 1)" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-filterStatus="@ViewBag.CurrentStatusFilter" asp-route-searchString="@ViewBag.CurrentFilter">Sau <i class="bi bi-chevron-right ms-1"></i></a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div> 
    <div class="row g-4 mt-2 mb-5">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 fs-6 fw-medium">Tổng số hồ sơ</p>
                        <h2 class="mb-0 fw-bold text-dark">@ViewBag.TotalAllRecords</h2>
                    </div>
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; background-color: #f0f4ff;">
                        <i class="bi bi-folder2-open fs-3" style="color: #4361ee;"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 fs-6 fw-medium">Khám hôm nay</p>
                        <h2 class="mb-0 fw-bold" style="color: #198754;">@ViewBag.TotalRecordsToday</h2>
                    </div>
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; background-color: #e8f5e9;">
                        <i class="bi bi-calendar-check fs-3" style="color: #198754;"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 fs-6 fw-medium">Đang chờ CLS</p>
                        <h2 class="mb-0 fw-bold" style="color: #fd7e14;">@ViewBag.TotalPending</h2>
                    </div>
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; background-color: #fff3e0;">
                        <i class="bi bi-hourglass-split fs-3" style="color: #fd7e14;"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 fs-6 fw-medium">Đã có kết quả</p>
                        <h2 class="mb-0 fw-bold" style="color: #0dcaf0;">@ViewBag.TotalCompleted</h2>
                    </div>
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; background-color: #e0f7fa;">
                        <i class="bi bi-lightning-charge fs-3" style="color: #0dcaf0;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Hàm tải lại DataGrid bằng AJAX
            function loadGridData(url) {
                $('#record-grid-container').css('opacity', '0.4');
                $('#record-grid-container').load(url + ' #record-grid-container > *', function (response, status, xhr) {
                    if (status == "error") {
                        alert("Lỗi tải dữ liệu. Vui lòng thử lại!");
                    }
                    $('#record-grid-container').css('opacity', '1');
                });
            }

            // Bắt sự kiện Submit ô Search
            $('#searchForm').on('submit', function (e) {
                e.preventDefault();
                var url = $(this).attr('action') + '?' + $(this).serialize(); 
                loadGridData(url);
            });

            // Bắt sự kiện Click Sắp xếp, Bộ lọc, Phân trang
            $(document).on('click', '.ajax-link', function (e) {
                e.preventDefault(); 
                var url = $(this).attr('href');
                
                // Đồng bộ text trên thanh tìm kiếm (để tránh bị mất value cũ)
                var searchVal = $('input[name="searchString"]').val();
                if(searchVal && !url.includes('searchString=')) {
                    url += (url.includes('?') ? '&' : '?') + 'searchString=' + encodeURIComponent(searchVal);
                }
                
                loadGridData(url);
            });
        });
    </script>
}