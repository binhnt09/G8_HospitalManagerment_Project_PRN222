@model IEnumerable<G8_HospitalManagerment_Project_PRN222.Models.MedicalRecord>

@{
    ViewData["Title"] = "Medical Records";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container-fluid py-4" style="background-color: #F8F9FA; min-height: 100vh;">

    @* ── Top bar ── *@
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        
        <form asp-action="Index" method="get" class="d-flex flex-grow-1" style="max-width: 500px;">
            <div class="input-group shadow-sm rounded-pill overflow-hidden bg-white border-0">
                <span class="input-group-text bg-transparent border-0 text-muted ps-4">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" name="searchString" value="@ViewBag.CurrentFilter" class="form-control border-0 shadow-none bg-transparent" placeholder="Search by Diagnosis, Doctor, Patient..." aria-label="Search">
                <button class="btn btn-primary rounded-pill m-1 px-4 fw-medium" type="submit">Search</button>
            </div>
            <input type="hidden" name="sortOrder" value="@ViewBag.CurrentSort" />
        </form>

        <div class="d-flex gap-2">
            <div class="dropdown shadow-sm rounded-pill">
                <button class="btn btn-white bg-white border-0 rounded-pill px-4 py-2 d-flex align-items-center gap-2 fw-medium text-dark" type="button" id="sortMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-sort-down text-primary"></i> Sort By
                </button>
                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm rounded-3 mt-2" aria-labelledby="sortMenuButton">
                    <li><a class="dropdown-item py-2" asp-action="Index" asp-route-sortOrder="@ViewBag.DateSortParm" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-calendar-event me-2 text-muted"></i>Record Date</a></li>
                    <li><a class="dropdown-item py-2" asp-action="Index" asp-route-sortOrder="doctor_asc" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-person-badge me-2 text-muted"></i>Doctor Name</a></li>
                    <li><a class="dropdown-item py-2" asp-action="Index" asp-route-sortOrder="patient_asc" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-person me-2 text-muted"></i>Patient Name</a></li>
                </ul>
            </div>
            
            @* <a asp-action="Create" class="open-modal-btn btn btn-primary rounded-pill px-4 py-2 d-flex align-items-center gap-2 fw-medium shadow-sm">
                <i class="bi bi-plus-lg"></i> New Record
            </a> *@
        </div>
    </div>

    @* ── Alerts ── *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm mb-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ── Data Table ── *@
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size: 0.95rem;">
                    <thead class="text-muted" style="background-color: #FAFAFA; font-size: 0.85rem; text-transform: uppercase;">
                        <tr>
                            <th class="ps-4 py-3 border-bottom-0 fw-semibold">ID</th>
                            <th class="py-3 border-bottom-0 fw-semibold">
                                <a asp-action="Index" asp-route-sortOrder="@ViewBag.DateSortParm" asp-route-searchString="@ViewBag.CurrentFilter" class="text-decoration-none text-muted">
                                    Date <i class="bi bi-arrow-down-up ms-1"></i>
                                </a>
                            </th>
                            <th class="py-3 border-bottom-0 fw-semibold">
                                <a asp-action="Index" asp-route-sortOrder="patient_asc" asp-route-searchString="@ViewBag.CurrentFilter" class="text-decoration-none text-muted">
                                    Patient <i class="bi bi-arrow-down-up ms-1"></i>
                                </a>
                            </th>
                            <th class="py-3 border-bottom-0 fw-semibold">
                                <a asp-action="Index" asp-route-sortOrder="doctor_asc" asp-route-searchString="@ViewBag.CurrentFilter" class="text-decoration-none text-muted">
                                    Doctor <i class="bi bi-arrow-down-up ms-1"></i>
                                </a>
                            </th>
                            <th class="py-3 border-bottom-0 fw-semibold">Diagnosis</th>
                            <th class="pe-4 py-3 border-bottom-0 fw-semibold text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var item in Model)
                        {
                            var patientName = item.Patient?.User != null
                                ? $"{item.Patient.User.FirstName ?? ""} {item.Patient.User.LastName ?? ""}".Trim()
                                : "Unknown Patient";
                            if (string.IsNullOrEmpty(patientName)) { patientName = "Unknown Patient"; }

                            var doctorName = item.Doctor?.Employee?.User != null
                                ? $"Dr. {item.Doctor.Employee.User.FirstName ?? ""} {item.Doctor.Employee.User.LastName ?? ""}".Trim()
                                : "Unknown Doctor";
                            if (string.IsNullOrEmpty(doctorName) || doctorName == "Dr.") { doctorName = "Unknown Doctor"; }

                            var diagnosis = !string.IsNullOrEmpty(item.Diagnosis)
                                ? (item.Diagnosis.Length > 40 ? item.Diagnosis.Substring(0, 40) + "..." : item.Diagnosis)
                                : "No diagnosis recorded";

                            <tr>
                                <td class="ps-4 py-3">
                                    <span class="badge bg-secondary-subtle text-secondary rounded-pill px-3 py-2">
                                        #@(item.RecordId)
                                    </span>
                                </td>
                                <td class="py-3">
                                    <div class="fw-bold text-dark">@(item.RecordDate?.ToString("yyyy-MM-dd") ?? "N/A")</div>
                                    <div class="text-muted small">@(item.RecordDate?.ToString("HH:mm") ?? "")</div>
                                </td>
                                <td class="py-3">
                                    <div class="fw-bold text-dark">@patientName</div>
                                    <div class="text-muted small">ID: @(item.PatientId)</div>
                                </td>
                                <td class="py-3">
                                    <div class="fw-bold text-dark">@doctorName</div>
                                    <div class="text-muted small">@(item.Doctor?.Specialization ?? "General")</div>
                                </td>
                                <td class="py-3">
                                    <span class="text-dark">@diagnosis</span>
                                </td>
                                <td class="pe-4 py-3 text-end">
                                    <a asp-action="Details" asp-route-id="@item.RecordId" class="open-modal-btn btn btn-sm btn-light text-muted p-2 rounded-circle me-1" title="Details"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.RecordId" class="open-modal-btn btn btn-sm btn-light text-primary p-2 rounded-circle me-1" title="Edit"><i class="bi bi-pencil-square"></i></a>
                                    <div class="dropdown d-inline">
                                        <button class="btn btn-sm btn-light text-muted p-2 rounded-circle" type="button" data-bs-toggle="dropdown" title="Options">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-1">
                                            @if (item.AppointmentId != null)
                                            {
                                                <li>
                                                    <a asp-controller="Invoices" asp-action="GenerateInvoice" 
                                                       asp-route-appointmentId="@item.AppointmentId" 
                                                       class="dropdown-item text-success">
                                                       <i class="bi bi-receipt me-2"></i>Generate Invoice
                                                    </a>
                                                </li>
                                            }
                                            <li><a class="open-modal-btn dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.RecordId"><i class="bi bi-trash3 me-2"></i>Delete</a></li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="bi bi-journal-x fs-1 d-block mb-2"></i>
                                    No medical records found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <div class="d-flex justify-content-between align-items-center p-4 border-top">
                <div class="text-muted" style="font-size: 0.9rem;">
                    Showing <span class="fw-bold text-dark">@ViewBag.ItemStart</span> to <span class="fw-bold text-dark">@ViewBag.ItemEnd</span> of <span class="fw-bold text-dark">@ViewBag.TotalItems</span> records
                </div>
                
                @if (totalPages > 1)
                {
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link rounded-pill border-0 text-muted px-3" asp-action="Index" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-searchString="@ViewBag.CurrentFilter" asp-route-pageNumber="@(currentPage - 1)"><i class="bi bi-chevron-left me-1"></i> Previous</a>
                        </li>
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link rounded-circle border-0 mx-1 @(i == currentPage ? "bg-primary text-white" : "text-dark")" asp-action="Index" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-searchString="@ViewBag.CurrentFilter" asp-route-pageNumber="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link rounded-pill border-0 text-muted px-3" asp-action="Index" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-searchString="@ViewBag.CurrentFilter" asp-route-pageNumber="@(currentPage + 1)">Next <i class="bi bi-chevron-right ms-1"></i></a>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
