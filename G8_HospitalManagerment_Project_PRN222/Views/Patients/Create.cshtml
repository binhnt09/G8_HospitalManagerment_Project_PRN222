@model G8_HospitalManagerment_Project_PRN222.Models.Patient

@{
    ViewData["Title"] = "Thêm Bệnh nhân Mới";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid py-4" style="background-color: #F8F9FA; min-height: 100vh;">
    <div class="card shadow-sm p-4 mx-auto border-0 rounded-4" style="max-width: 800px;">
        <div class="d-flex align-items-center mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; background-color: #e8f0fe;">
                <i class="bi bi-person-plus fs-4 text-primary"></i>
            </div>
            <h2 class="mb-0 fw-bold text-dark">Thêm Bệnh nhân Mới</h2>
        </div>
        <hr class="mb-4" />

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="UserId" class="form-label fw-medium text-muted">Tài khoản User liên kết</label>
                    <select asp-for="UserId" class="form-select" asp-items="ViewBag.UserId">
                        <option value="">-- Chọn User --</option>
                    </select>
                    <span asp-validation-for="UserId" class="text-danger small"></span>
                </div>
                
                <div class="col-md-6">
                    <label asp-for="BloodType" class="form-label fw-medium text-muted">Nhóm máu</label>
                    <input asp-for="BloodType" class="form-control" placeholder="VD: O+, A-, AB..." />
                    <span asp-validation-for="BloodType" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="InsuranceNumber" class="form-label fw-medium text-muted">Số BHYT</label>
                    <input asp-for="InsuranceNumber" class="form-control" placeholder="Nhập mã thẻ bảo hiểm y tế..." />
                    <span asp-validation-for="InsuranceNumber" class="text-danger small"></span>
                </div>
                
                <div class="col-md-6">
                    <label asp-for="Allergies" class="form-label fw-medium text-muted">Tiền sử Dị ứng</label>
                    <input asp-for="Allergies" class="form-control" placeholder="Thuốc, thức ăn..." />
                    <span asp-validation-for="Allergies" class="text-danger small"></span>
                </div>
                
                <div class="col-md-12">
                    <label asp-for="DeletedAt" class="form-label fw-medium text-muted">Ngày xóa (Bỏ qua nếu tạo mới)</label>
                    <input asp-for="DeletedAt" class="form-control" type="datetime-local" />
                    <span asp-validation-for="DeletedAt" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-5 pt-3 border-top">
                <button type="submit" class="btn btn-primary px-4 rounded-pill fw-medium d-flex align-items-center">
                    <i class="bi bi-check2-circle me-2"></i> Lưu Bệnh nhân
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill fw-medium d-flex align-items-center">
                    <i class="bi bi-arrow-left me-2"></i> Trở về Danh sách
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
