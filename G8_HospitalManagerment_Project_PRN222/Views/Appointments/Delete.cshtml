@model G8_HospitalManagerment_Project_PRN222.Models.Appointment

@{
    ViewData["Title"] = "Delete Appointment";
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card medical-card p-4">
                    <div class="card-body">
                        <h1 class="fw-bold mb-2">Delete Appointment</h1>
                        <p class="text-muted mb-3">Are you sure you want to delete this appointment?</p>

                        <div>
                            <h4>Appointment</h4>
                            <hr />
                            <dl class="row">
                                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.AppointmentDate)</dt>
                                <dd class="col-sm-8">@Html.DisplayFor(model => model.AppointmentDate)</dd>

                                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Reason)</dt>
                                <dd class="col-sm-8">@Html.DisplayFor(model => model.Reason)</dd>

                                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Status)</dt>
                                <dd class="col-sm-8">@Html.DisplayFor(model => model.Status)</dd>

                                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Department)</dt>
                                <dd class="col-sm-8">@Html.DisplayFor(model => model.Department.DepartmentId)</dd>

                                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Doctor)</dt>
                                <dd class="col-sm-8">@Html.DisplayFor(model => model.Doctor.DoctorId)</dd>

                                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Patient)</dt>
                                <dd class="col-sm-8">@Html.DisplayFor(model => model.Patient.PatientId)</dd>
                            </dl>

                            <form asp-action="Delete">
                                @Html.AntiForgeryToken()
                                <input type="hidden" asp-for="AppointmentId" />
                                <div class="d-flex gap-2">
                                    <input type="submit" value="Delete" class="btn btn-danger" />
                                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    .medical-card {
        background-color: #f8f9fa;
        border-radius: 15px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }
    .btn-medical {
        background-color: rgb(64, 233, 64);
        color: white;
    }
    .btn-medical:hover {
        background-color: rgb(12, 182, 12);
    }
</style>
