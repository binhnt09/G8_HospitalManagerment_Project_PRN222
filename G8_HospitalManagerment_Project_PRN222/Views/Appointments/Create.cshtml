@model G8_HospitalManagerment_Project_PRN222.Models.Appointment

@{
    ViewData["Title"] = "Create an Appointment";
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card medical-card p-4">
                    <div class="card-body">
                        <h1 class="fw-bold mb-2">Create an Appointment For Patient</h1>
                        @* <p class="text-muted mb-4">Vui lòng điền thông tin dưới đây để tạo lịch khám với bác sĩ của chúng tôi.</p> *@

                        <form asp-action="Create">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="All" class="text-danger mb-3"></div>

                            <div class="mb-3">
                                <label class="form-label">Patient</label>
                                <select asp-for="PatientId" class="form-select" asp-items="ViewBag.PatientId"></select>
                                <span asp-validation-for="PatientId" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Doctor</label>
                                <select asp-for="DoctorId" class="form-select" asp-items="ViewBag.DoctorId"></select>
                                <span asp-validation-for="DoctorId" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Department</label>
                                <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.DepartmentId"></select>
                                <span asp-validation-for="DepartmentId" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="AppointmentDate" class="form-label"></label>
                                <input asp-for="AppointmentDate" class="form-control" type="datetime-local" />
                                <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Reason" class="form-label"></label>
                                <input asp-for="Reason" class="form-control" />
                                <span asp-validation-for="Reason" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Status" class="form-label"></label>
                                <select asp-for="Status" class="form-select" asp-items="ViewBag.Status"></select>
                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>

                            <div class="d-flex gap-2">
                                <input type="submit" value="Create Appointment" class="btn btn-medical"/>
                                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    .medical-card {
        background-color: #f8f9fa;
        border-radius: 15px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }
    .btn-medical {
        background-color: rgb(64, 233, 64);
        color: white;
    }
    .btn-medical:hover {
        background-color: rgb(12, 182, 12);
    }
