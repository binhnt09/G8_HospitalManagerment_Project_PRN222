@model IEnumerable<G8_HospitalManagerment_Project_PRN222.Models.Appointment>

@{
    ViewData["Title"] = "Appointments Management";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container-fluid py-4" style="background-color: #F8F9FA; min-height: 100vh;">
    
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        
        <form asp-action="Index" method="get" class="d-flex flex-grow-1" style="max-width: 500px;">
            <div class="input-group shadow-sm rounded-pill overflow-hidden bg-white border-0">
                <span class="input-group-text bg-transparent border-0 text-muted ps-4">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" name="searchString" value="@ViewBag.CurrentFilter" class="form-control border-0 shadow-none bg-transparent" placeholder="Search by Reason, Doctor, Patient..." aria-label="Search">
                <button class="btn btn-primary rounded-pill m-1 px-4 fw-medium" type="submit">Search</button>
            </div>
            <input type="hidden" name="sortOrder" value="@ViewBag.CurrentSort" />
        </form>

        <div class="d-flex gap-2">
            <div class="dropdown shadow-sm rounded-pill">
                <button class="btn btn-white bg-white border-0 rounded-pill px-4 py-2 d-flex align-items-center gap-2 fw-medium text-dark" type="button" id="sortMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-sort-down text-primary"></i> Sort By
                </button>
                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm rounded-3 mt-2" aria-labelledby="sortMenuButton">
                    <li><a class="dropdown-item py-2" asp-action="Index" asp-route-sortOrder="@ViewBag.DateSortParm" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-calendar-event me-2 text-muted"></i>Appointment Date</a></li>
                    <li><a class="dropdown-item py-2" asp-action="Index" asp-route-sortOrder="doctor_asc" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-person-badge me-2 text-muted"></i>Doctor Name</a></li>
                    <li><a class="dropdown-item py-2" asp-action="Index" asp-route-sortOrder="status_asc" asp-route-searchString="@ViewBag.CurrentFilter"><i class="bi bi-circle-half me-2 text-muted"></i>Status</a></li>
                </ul>
            </div>
            
            <a asp-action="Create" class="open-modal-btn btn btn-primary rounded-pill px-4 py-2 d-flex align-items-center gap-2 fw-medium shadow-sm">
                <i class="bi bi-plus-lg"></i> New Appointment
            </a>
        </div>
    </div>
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size: 0.95rem;">
                    <thead class="text-muted" style="background-color: #FAFAFA; font-size: 0.85rem; text-transform: uppercase;">
                        <tr>
                            <th class="ps-4 py-3 border-bottom-0 fw-semibold">
                                <a asp-action="Index" asp-route-sortOrder="@ViewBag.DateSortParm" asp-route-searchString="@ViewBag.CurrentFilter" class="text-decoration-none text-muted">
                                    Appointment Date <i class="bi bi-arrow-down-up ms-1"></i>
                                </a>
                            </th>
                            <th class="py-3 border-bottom-0 fw-semibold">Reason</th>
                            <th class="py-3 border-bottom-0 fw-semibold">Doctor</th>
                            <th class="py-3 border-bottom-0 fw-semibold">Patient</th>
                            <th class="py-3 border-bottom-0 fw-semibold">Department</th>
                            <th class="py-3 border-bottom-0 fw-semibold">Status</th>
                            <th class="py-3 border-bottom-0 fw-semibold">Record Status</th>
                            <th class="pe-4 py-3 border-bottom-0 fw-semibold text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var item in Model) {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="fw-bold text-dark">@item.AppointmentDate.ToString("yyyy-MM-dd")</div>
                                    <div class="text-muted small">@item.AppointmentDate.ToString("yyyy-MM-dd HH:mm")</div>
                                </td>
                                <td class="py-3">
                                    <div class="text-dark">@item.Reason</div>
                                </td>
                                <td class="py-3">
                                    <div class="fw-bold text-dark">@(item.Doctor?.Employee?.User?.FirstName) @(item.Doctor?.Employee?.User?.LastName)</div>
                                    <div class="text-muted small">Dr. @item.Doctor?.DoctorId</div>
                                </td>
                                <td class="py-3">
                                    <div class="fw-bold text-dark">@(item.Patient?.User?.FirstName) @(item.Patient?.User?.LastName)</div>
                                    <div class="text-muted small">@item.Patient?.PatientId</div>
                                </td>
                                <td class="py-3">
                                    <div class="text-dark">@item.Department?.DepartmentName</div>
                                </td>
                                <td class="py-3">
                                    @if(item.Status == "Completed") {
                                        <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2">Completed</span>
                                    } else if(item.Status == "Scheduled") {
                                        <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">Scheduled</span>
                                    } else if(item.Status == "In Progress") {
                                        <span class="badge bg-warning-subtle text-warning rounded-pill px-3 py-2">In Progress</span>
                                    } else {
                                        <span class="badge bg-danger-subtle text-danger rounded-pill px-3 py-2">Cancelled</span>
                                    }
                                </td>
                                <td class="py-3">
                                    @if(item.IsDeleted == true) {
                                        <span class="badge bg-danger-subtle text-danger rounded-pill px-3 py-2">Deleted</span>
                                    } else {
                                        <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2">Active</span>
                                    }
                                </td>
                                <td class="pe-4 py-3 text-end">
                                    <a asp-action="Details" asp-route-id="@item.AppointmentId" class="open-modal-btn btn btn-sm btn-light text-muted p-2 rounded-circle me-1"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.AppointmentId" class="open-modal-btn btn btn-sm btn-light text-primary p-2 rounded-circle me-1"><i class="bi bi-pencil-square"></i></a>
                                    <div class="dropdown d-inline">
                                        <button class="btn btn-sm btn-light text-muted p-2 rounded-circle" type="button" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-1">
                                            <li><a class="open-modal-btn dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.AppointmentId"><i class="bi bi-trash3 me-2"></i>Delete</a></li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-between align-items-center p-4 border-top">
                <div class="text-muted" style="font-size: 0.9rem;">
                    Showing <span class="fw-bold text-dark">@ViewBag.ItemStart</span> to <span class="fw-bold text-dark">@ViewBag.ItemEnd</span> of <span class="fw-bold text-dark">@ViewBag.TotalItems</span> appointments
                </div>
                
                @if (totalPages > 1)
                {
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link rounded-pill border-0 text-muted px-3" asp-action="Index" asp-route-pageNumber="@(currentPage - 1)"><i class="bi bi-chevron-left me-1"></i> Previous</a>
                        </li>
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link rounded-circle border-0 mx-1 @(i == currentPage ? "bg-primary text-white" : "text-dark")" asp-action="Index" asp-route-pageNumber="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link rounded-pill border-0 text-muted px-3" asp-action="Index" asp-route-pageNumber="@(currentPage + 1)">Next <i class="bi bi-chevron-right ms-1"></i></a>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted mb-1" style="font-size: 0.9rem;">Total Appointments</div>
                        <h3 class="fw-bold mb-0 text-dark">@ViewBag.TotalAppointments</h3>
                    </div>
                    <div class="rounded-circle d-flex justify-content-center align-items-center" style="width: 50px; height: 50px; background-color: #E8F0FE; color: #1A73E8;">
                        <i class="bi bi-calendar-event fs-5"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted mb-1" style="font-size: 0.9rem;">Completed</div>
                        <h3 class="fw-bold mb-0 text-success">@ViewBag.CompletedCount</h3>
                    </div>
                    <div class="rounded-circle d-flex justify-content-center align-items-center" style="width: 50px; height: 50px; background-color: #E6F4EA; color: #1E8E3E;">
                        <i class="bi bi-check-lg fs-5"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted mb-1" style="font-size: 0.9rem;">Scheduled</div>
                        <h3 class="fw-bold mb-0 text-primary">@ViewBag.ScheduledCount</h3>
                    </div>
                    <div class="rounded-circle d-flex justify-content-center align-items-center" style="width: 50px; height: 50px; background-color: #E8F0FE; color: #1A73E8;">
                        <i class="bi bi-clock-history fs-5"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted mb-1" style="font-size: 0.9rem;">Active</div>
                        <h3 class="fw-bold mb-0 text-primary">@ViewBag.ActiveCount</h3>
                    </div>
                    <div class="rounded-circle d-flex justify-content-center align-items-center" style="width: 50px; height: 50px; background-color: #E8F0FE; color: #1A73E8;">
                        <i class="bi bi-lightning-charge fs-5"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
