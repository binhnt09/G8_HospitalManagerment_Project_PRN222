@model IEnumerable<G8_HospitalManagerment_Project_PRN222.Models.Appointment>

@{
    ViewData["Title"] = "Danh sách lịch khám";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h6 class="text-medical fw-bold text-uppercase">Lịch khám</h6>
                <h2 class="fw-bold mb-0">Danh sách lịch khám</h2>
            </div>

            <div>
                <a asp-action="Create" class="btn btn-medical d-flex align-items-center gap-2">
                    <i class="bi bi-calendar2-plus"></i> Đặt lịch khám
                </a>
            </div>
        </div>

        <div class="card medical-card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>@Html.DisplayNameFor(model => model.AppointmentDate)</th>
                                <th>@Html.DisplayNameFor(model => model.Reason)</th>
                                <th>@Html.DisplayNameFor(model => model.Status)</th>
                                <th>@Html.DisplayNameFor(model => model.CreatedAt)</th>
                                <th>@Html.DisplayNameFor(model => model.UpdatedAt)</th>
                                <th>@Html.DisplayNameFor(model => model.Department)</th>
                                <th>@Html.DisplayNameFor(model => model.Doctor)</th>
                                <th>@Html.DisplayNameFor(model => model.Patient)</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model) {
                            <tr>
                                <td>@Html.DisplayFor(modelItem => item.AppointmentDate)</td>
                                <td>@Html.DisplayFor(modelItem => item.Reason)</td>
                                <td>@Html.DisplayFor(modelItem => item.Status)</td>
                                <td>@Html.DisplayFor(modelItem => item.CreatedAt)</td>
                                <td>@Html.DisplayFor(modelItem => item.UpdatedAt)</td>
                                <td>@(item.Department != null ? item.Department.DepartmentId.ToString() : "-")</td>
                                <td>@(item.Doctor != null ? item.Doctor.DoctorId.ToString() : "-")</td>
                                <td>@(item.Patient != null ? item.Patient.PatientId.ToString() : "-")</td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.AppointmentId" class="btn btn-sm btn-outline-primary">Edit</a>
                                        <a asp-action="Details" asp-route-id="@item.AppointmentId" class="btn btn-sm btn-outline-secondary">Details</a>
                                        <a asp-action="Delete" asp-route-id="@item.AppointmentId" class="btn btn-sm btn-outline-danger">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>
