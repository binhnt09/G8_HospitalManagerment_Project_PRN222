@model List<string>

<div class="container mt-4">
    <div class="card shadow border-0" style="border-radius: 15px; background: #121212;">
        <div class="card-header bg-dark text-success py-3 d-flex justify-content-between align-items-center" style="border-radius: 15px 15px 0 0; border-bottom: 1px solid #333;">
            <h5 class="mb-0"><i class="fas fa-terminal me-2"></i> TCP MONITOR - PORT 13000</h5>
            <span class="badge bg-success">ONLINE</span>
        </div>
        <div class="card-body p-4">
            <div id="logBox" class="bg-black p-3 rounded-3" style="height: 450px; overflow-y: auto; font-family: 'Consolas', monospace; color: #00ff00; border: 1px solid #444;">
                <div class="text-muted mb-2 small">>> Khởi tạo hệ thống theo dõi...</div>

                @if (Model != null && Model.Any())
                {
                    @foreach (var log in Model)
                    {
                        <div class="mb-1">
                            <span class="text-warning">>></span> @log
                        </div>
                    }
                }
                else
                {
                    <div class="text-muted italic">Đang chờ kết nối từ Client...</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tự động reload sau 3 giây để cập nhật log mới nhất
        setTimeout(function() {
            location.reload();
        }, 3000);

        // Tự động cuộn xuống cuối log box
        var logBox = document.getElementById("logBox");
        logBox.scrollTop = logBox.scrollHeight;
    </script>
}